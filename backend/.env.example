# =============================================================================
# POE Knowledge Assistant - Environment Configuration
# =============================================================================
#
# This file contains all configuration options for the POE Knowledge Assistant.
# Copy this file to .env and customize the values for your environment.
#
# USAGE:
#   cp .env.example .env
#   # Edit .env with your actual values
#
# VALIDATION:
#   - Required fields are marked with [REQUIRED]
#   - Optional fields are marked with [OPTIONAL]
#   - Fields with defaults work without modification in development
#
# SECURITY WARNING:
#   - Never commit .env files to version control
#   - Always use strong, unique SECRET_KEY in production
#   - Rotate API keys regularly
#   - Use environment-specific credentials
#
# =============================================================================


# =============================================================================
# SECTION 1: APPLICATION METADATA
# =============================================================================
# Basic application information displayed in logs and API responses.

# [OPTIONAL] Application display name
# Default: POE Knowledge Assistant
APP_NAME=POE Knowledge Assistant

# [OPTIONAL] Application version string
# Default: 1.0.0
APP_VERSION=1.0.0

# [REQUIRED] Application environment
# Options: development, testing, production
# Validation: Must be one of the valid environment values
# IMPORTANT: Change to 'production' for production deployments
ENVIRONMENT=development


# =============================================================================
# SECTION 2: SERVER CONFIGURATION
# =============================================================================
# FastAPI server settings for API hosting.
# All settings prefixed with API_

# [OPTIONAL] Server host address
# Default: 0.0.0.0 (all interfaces)
# Production recommendation: Use specific IP or reverse proxy
API_HOST=0.0.0.0

# [OPTIONAL] Server port number
# Default: 8000
# Validation: Must be a valid port number (1-65535)
# Production recommendation: Use port 80/443 behind reverse proxy
API_PORT=8000

# [OPTIONAL] Enable debug mode
# Default: True in development, False recommended for production
# WARNING: Never enable debug mode in production - exposes sensitive info
API_DEBUG=True

# [OPTIONAL] Enable auto-reload on code changes
# Default: True
# WARNING: Disable in production (performance impact)
API_RELOAD=True

# [OPTIONAL] Number of worker processes
# Default: 1
# Performance: Increase for production (recommended: CPU cores * 2 + 1)
# Note: Only applies when using Gunicorn/Uvicorn workers
API_WORKERS=1


# =============================================================================
# SECTION 3: DATABASE CONFIGURATION
# =============================================================================
# Primary database settings (PostgreSQL recommended for production).

# [REQUIRED] Database connection URL
# SQLite (development): sqlite:///./data/poe_knowledge.db
# PostgreSQL (production): postgresql://user:password@localhost:5432/poe_knowledge
# Validation: Must be a valid database URL
DATABASE_URL=sqlite:///./data/poe_knowledge.db

# [OPTIONAL] Connection pool size
# Default: 5
# Performance: Increase for high-traffic production (10-20)
# Validation: Must be positive integer
DATABASE_POOL_SIZE=5

# [OPTIONAL] Maximum overflow connections
# Default: 10
# Performance: Additional connections beyond pool size
# Validation: Must be positive integer
DATABASE_MAX_OVERFLOW=10


# =============================================================================
# SECTION 4: VECTOR DATABASE (ChromaDB)
# =============================================================================
# Vector database for semantic search and RAG functionality.
# All settings prefixed with CHROMA_

# [OPTIONAL] Directory for persistent storage
# Default: ./data/chroma
# Production: Use absolute path with proper permissions
CHROMA_PERSIST_DIRECTORY=./data/chroma

# [OPTIONAL] Collection name for knowledge base
# Default: poe_knowledge
# Use different collections for different knowledge domains
CHROMA_COLLECTION_NAME=poe_knowledge


# =============================================================================
# SECTION 5: LLM PROVIDER CONFIGURATION
# =============================================================================
# Large Language Model provider settings.
# Choose one provider and configure its specific settings.

# -----------------------------------------------------------------------------
# 5.1 Provider Selection
# -----------------------------------------------------------------------------

# [REQUIRED] LLM provider to use
# Options: openai, anthropic, ollama, lmstudio
# Validation: Must be one of the valid provider values
PROVIDER=anthropic

# -----------------------------------------------------------------------------
# 5.2 OpenAI Configuration
# -----------------------------------------------------------------------------
# Required when LLM_PROVIDER=openai

# [REQUIRED if LLM_PROVIDER=openai] OpenAI API key
# Get your key at: https://platform.openai.com/api-keys
# Security: Never expose this key in client-side code
# Validation: Must start with 'sk-' and be valid API key
OPENAI_API_KEY=sk-your-openai-api-key-here

# [OPTIONAL] OpenAI model to use
# Default: gpt-4
# Options: gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo, etc.
# Performance: gpt-4 for quality, gpt-3.5-turbo for speed/cost
OPENAI_MODEL=gpt-4

# [OPTIONAL] Response randomness/creativity
# Default: 0.7
# Range: 0.0 (deterministic) to 2.0 (very creative)
# Recommendation: 0.7-0.9 for general use, 0.0-0.3 for factual responses
OPENAI_TEMPERATURE=0.7

# [OPTIONAL] Maximum tokens in response
# Default: 2000
# Range: 1 to model's maximum (varies by model)
# Performance: Higher values increase cost and latency
OPENAI_MAX_TOKENS=2000

# -----------------------------------------------------------------------------
# 5.3 Anthropic Configuration
# -----------------------------------------------------------------------------
# Required when LLM_PROVIDER=anthropic

# [REQUIRED if LLM_PROVIDER=anthropic] Anthropic API key
# Get your key at: https://console.anthropic.com/
# Security: Never expose this key in client-side code
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# [OPTIONAL] Anthropic API base URL (for compatible proxies)
#ANTHROPIC_BASE_URL=https://api.anthropic.com

# [OPTIONAL] Anthropic model to use
# Default: claude-3-sonnet-20240229
# Options: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
# Performance: opus for quality, haiku for speed, sonnet for balance
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# [OPTIONAL] Response randomness/creativity
# Default: 0.7
# Range: 0.0 to 1.0
ANTHROPIC_TEMPERATURE=0.7

# [OPTIONAL] Maximum tokens in response
# Default: 2000
# Range: 1 to model's maximum
ANTHROPIC_MAX_TOKENS=2000

# -----------------------------------------------------------------------------
# 5.4 Ollama Configuration (Local LLM)
# -----------------------------------------------------------------------------
# Required when LLM_PROVIDER=ollama
# Install: https://ollama.ai/

# [OPTIONAL] Ollama server base URL
# Default: http://localhost:11434
# Change if running Ollama on different host/port
OLLAMA_BASE_URL=http://localhost:11434

# [OPTIONAL] Ollama model to use
# Default: llama2
# Options: llama2, mistral, codellama, etc.
# Run 'ollama list' to see available models
OLLAMA_MODEL=llama2

# [OPTIONAL] Response randomness/creativity
# Default: 0.7
# Range: 0.0 to 1.0
OLLAMA_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# 5.5 LM Studio Configuration (Local LLM)
# -----------------------------------------------------------------------------
# Required when LLM_PROVIDER=lmstudio
# Install: https://lmstudio.ai/

# [OPTIONAL] LM Studio server base URL
# Default: http://localhost:1234
# Change if using different port
LMSTUDIO_BASE_URL=http://localhost:1234

# [OPTIONAL] Model identifier
# Default: local-model
# Set to match your loaded model in LM Studio
LMSTUDIO_MODEL=local-model

# [OPTIONAL] Response randomness/creativity
# Default: 0.7
# Range: 0.0 to 2.0
LMSTUDIO_TEMPERATURE=0.7


# =============================================================================
# SECTION 6: EMBEDDING PROVIDER CONFIGURATION
# =============================================================================
# Embedding model settings for vector generation.
# All settings prefixed with EMBEDDING_

# -----------------------------------------------------------------------------
# 6.1 Provider Selection
# -----------------------------------------------------------------------------

# [REQUIRED] Embedding provider to use
# Options: local, ollama, lmstudio, openai
# Recommendation: 'local' for free/offline, 'openai' for quality
EMBEDDING_PROVIDER=local

# [OPTIONAL] Embedding model name
# Default: all-MiniLM-L6-v2 (for local provider)
# Local options: all-MiniLM-L6-v2, all-mpnet-base-v2, etc.
# OpenAI options: text-embedding-ada-002, text-embedding-3-small, text-embedding-3-large
EMBEDDING_MODEL=all-MiniLM-L6-v2

# [OPTIONAL] Embedding vector dimension
# Default: 384 (for all-MiniLM-L6-v2)
# Important: Must match model's output dimension
# all-MiniLM-L6-v2: 384, all-mpnet-base-v2: 768, ada-002: 1536
EMBEDDING_EMBEDDING_DIMENSION=384

# [OPTIONAL] Batch size for embedding generation
# Default: 32
# Performance: Increase for faster bulk processing (requires more memory)
EMBEDDING_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# 6.2 OpenAI Embeddings Configuration
# -----------------------------------------------------------------------------
# Required when EMBEDDING_PROVIDER=openai

# [REQUIRED if EMBEDDING_PROVIDER=openai] OpenAI API key for embeddings
# Can use same key as LLM or separate key for rate limiting
EMBEDDING_OPENAI_API_KEY=sk-your-openai-api-key-here

# [OPTIONAL] OpenAI embedding model
# Default: text-embedding-ada-002
# Options: text-embedding-ada-002, text-embedding-3-small, text-embedding-3-large
# Dimensions: ada-002=1536, 3-small=1536, 3-large=3072
EMBEDDING_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# -----------------------------------------------------------------------------
# 6.3 Ollama Embeddings Configuration
# -----------------------------------------------------------------------------
# Required when EMBEDDING_PROVIDER=ollama

# [OPTIONAL] Ollama server URL for embeddings
# Default: http://localhost:11434
EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434

# [OPTIONAL] Ollama embedding model
# Default: nomic-embed-text
# Options: nomic-embed-text, llama2-embeddings, etc.
EMBEDDING_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# 6.4 LM Studio Embeddings Configuration
# -----------------------------------------------------------------------------
# Required when EMBEDDING_PROVIDER=lmstudio

# [OPTIONAL] LM Studio server URL for embeddings
# Default: http://localhost:1234
EMBEDDING_LMSTUDIO_BASE_URL=http://localhost:1234


# =============================================================================
# SECTION 7: RAG PIPELINE SETTINGS
# =============================================================================
# Retrieval-Augmented Generation configuration.
# All settings prefixed with RAG_

# [OPTIONAL] Number of documents to retrieve for context
# Default: 3
# Performance: Higher values = more context but slower and more tokens
# Range: 1-20 typically
RAG_TOP_K_RESULTS=3

# [OPTIONAL] Document chunk size in characters
# Default: 1000
# Performance: Smaller chunks = more precise retrieval, larger = more context
# Recommendation: 500-1500 depending on content type
RAG_CHUNK_SIZE=1000

# [OPTIONAL] Overlap between chunks in characters
# Default: 200
# Purpose: Ensures context continuity across chunk boundaries
# Recommendation: 10-20% of chunk size
RAG_CHUNK_OVERLAP=200

# [OPTIONAL] Minimum similarity score threshold (0.0 to 1.0)
# Default: 0.7
# Purpose: Filter out low-relevance results
# Recommendation: 0.5-0.8 depending on precision needs
RAG_SCORE_THRESHOLD=0.7


# =============================================================================
# SECTION 8: SCRAPER SETTINGS
# =============================================================================
# Web scraper configuration for knowledge base ingestion.
# All settings prefixed with SCRAPER_

# [OPTIONAL] Delay between requests in seconds
# Default: 2.0
# Purpose: Rate limiting to avoid being blocked
# Recommendation: 1.0-3.0 for most sites
SCRAPER_RATE_LIMIT_DELAY=2.0

# [OPTIONAL] Maximum retry attempts for failed requests
# Default: 3
# Validation: Must be positive integer
SCRAPER_MAX_RETRIES=3

# [OPTIONAL] Request timeout in seconds
# Default: 30
# Performance: Higher for slow connections
SCRAPER_TIMEOUT=30

# [OPTIONAL] User agent string for HTTP requests
# Default: Mozilla/5.0 (compatible; POEKnowledgeBot/1.0)
# Purpose: Identify your bot to websites
# Recommendation: Use descriptive user agent for ethical scraping
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; POEKnowledgeBot/1.0)

# [OPTIONAL] Maximum concurrent requests
# Default: 5
# Performance: Increase for faster scraping (respect rate limits)
# Warning: Too high may get you blocked
SCRAPER_CONCURRENT_REQUESTS=5


# =============================================================================
# SECTION 9: CORS SETTINGS
# =============================================================================
# Cross-Origin Resource Sharing configuration.
# All settings prefixed with CORS_

# [REQUIRED] Allowed CORS origins (comma-separated)
# Development: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com,https://app.yourdomain.com
# Security: Be restrictive in production - never use '*' for credentials
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# [OPTIONAL] Allow credentials in CORS requests
# Default: True
# Security: Only enable if needed for cookies/auth headers
CORS_ALLOW_CREDENTIALS=True

# [OPTIONAL] Allowed HTTP methods
# Default: * (all methods)
# Options: *, GET, POST, PUT, DELETE, etc. (comma-separated)
CORS_ALLOW_METHODS=*

# [OPTIONAL] Allowed HTTP headers
# Default: * (all headers)
# Security: Consider restricting in production
CORS_ALLOW_HEADERS=*


# =============================================================================
# SECTION 10: SECURITY SETTINGS
# =============================================================================
# Authentication and security configuration.
# CRITICAL: Review all settings before production deployment.

# [REQUIRED] Secret key for JWT encoding
# Default: NOT SECURE - must change for production
# Validation: In production, must be changed from default
# Security: Use strong random string (min 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production-please

# [OPTIONAL] JWT algorithm
# Default: HS256
# Options: HS256, HS384, HS512, RS256, etc.
# Security: RS256 recommended for production (requires key pair)
ALGORITHM=HS256

# [OPTIONAL] Access token expiration time in minutes
# Default: 30
# Security: Lower values = more secure but more frequent re-auth
# Recommendation: 15-60 minutes depending on security requirements
ACCESS_TOKEN_EXPIRE_MINUTES=30

# [OPTIONAL] API key header name
# Default: X-API-Key
# Used for API key authentication
API_KEY_HEADER=X-API-Key


# =============================================================================
# SECTION 11: LOGGING SETTINGS
# =============================================================================
# Application logging configuration.
# All settings prefixed with LOG_

# [OPTIONAL] Logging level
# Default: INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Validation: Must be one of the valid levels
# Development: DEBUG or INFO
# Production: WARNING or ERROR
LOG_LEVEL=INFO

# [OPTIONAL] Log format string
# Default: %(asctime)s - %(name)s - %(levelname)s - %(message)s
# See Python logging documentation for format options
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# [OPTIONAL] Log file path (leave empty for console-only logging)
# Default: None (console only)
# Example: /var/log/poe_knowledge/app.log
# Production: Recommended to set a file path
LOG_FILE_PATH=

# [OPTIONAL] Maximum log file size in bytes
# Default: 10485760 (10MB)
# Purpose: Triggers log rotation when exceeded
LOG_MAX_BYTES=10485760

# [OPTIONAL] Number of backup log files to keep
# Default: 5
# Purpose: Controls log rotation history
LOG_BACKUP_COUNT=5


# =============================================================================
# SECTION 12: ENVIRONMENT-SPECIFIC OVERRIDES
# =============================================================================
# These sections provide recommended settings for different environments.
# Copy the relevant section to your .env file and adjust as needed.

# -----------------------------------------------------------------------------
# DEVELOPMENT ENVIRONMENT
# -----------------------------------------------------------------------------
# ENVIRONMENT=development
# API_DEBUG=True
# API_RELOAD=True
# API_WORKERS=1
# DATABASE_URL=sqlite:///./data/poe_knowledge.db
# LOG_LEVEL=DEBUG
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# TESTING ENVIRONMENT
# -----------------------------------------------------------------------------
# ENVIRONMENT=testing
# API_DEBUG=True
# API_RELOAD=False
# API_WORKERS=1
# DATABASE_URL=sqlite:///./data/test_poe_knowledge.db
# LOG_LEVEL=DEBUG
# CHROMA_PERSIST_DIRECTORY=./data/test_chroma
# CHROMA_COLLECTION_NAME=test_poe_knowledge

# -----------------------------------------------------------------------------
# PRODUCTION ENVIRONMENT
# -----------------------------------------------------------------------------
# ENVIRONMENT=production
# API_DEBUG=False
# API_RELOAD=False
# API_WORKERS=4
# DATABASE_URL=postgresql://user:password@localhost:5432/poe_knowledge
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
# LOG_LEVEL=WARNING
# LOG_FILE_PATH=/var/log/poe_knowledge/app.log
# CORS_ORIGINS=https://yourdomain.com
# SECRET_KEY=<generate-strong-random-key>
# ACCESS_TOKEN_EXPIRE_MINUTES=15


# =============================================================================
# SECTION 13: PERFORMANCE TUNING
# =============================================================================
# Advanced performance optimization settings.

# -----------------------------------------------------------------------------
# Database Performance
# -----------------------------------------------------------------------------
# DATABASE_POOL_SIZE=10           # Increase for high concurrency
# DATABASE_MAX_OVERFLOW=20        # Additional connections for spikes

# -----------------------------------------------------------------------------
# RAG Performance
# -----------------------------------------------------------------------------
# RAG_TOP_K_RESULTS=5             # More context, higher quality but slower
# RAG_CHUNK_SIZE=800              # Smaller chunks = more precise retrieval
# EMBEDDING_BATCH_SIZE=64         # Faster bulk embedding (more memory)

# -----------------------------------------------------------------------------
# Scraper Performance
# -----------------------------------------------------------------------------
# SCRAPER_CONCURRENT_REQUESTS=10  # Faster scraping (respect rate limits)
# SCRAPER_RATE_LIMIT_DELAY=1.0    # Faster but higher risk of blocking

# -----------------------------------------------------------------------------
# Server Performance
# -----------------------------------------------------------------------------
# API_WORKERS=4                   # Match CPU cores for production


# =============================================================================
# SECTION 14: SECURITY BEST PRACTICES CHECKLIST
# =============================================================================
# Before deploying to production, verify the following:

# [ ] SECRET_KEY is changed from default to strong random string
# [ ] API_DEBUG is set to False
# [ ] API_RELOAD is set to False
# [ ] All API keys are properly secured and rotated
# [ ] DATABASE_URL uses secure credentials
# [ ] CORS_ORIGINS is restricted to your domains only
# [ ] LOG_LEVEL is set to WARNING or ERROR
# [ ] LOG_FILE_PATH is set with proper permissions
# [ ] ACCESS_TOKEN_EXPIRE_MINUTES is appropriately short
# [ ] .env file is not committed to version control
# [ ] File permissions on .env are restrictive (chmod 600)

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
