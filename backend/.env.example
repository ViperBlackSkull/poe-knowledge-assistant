# =============================================================================
# POE Knowledge Assistant - Environment Configuration
# =============================================================================

# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=POE Knowledge Assistant
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, production, or testing

# Server Settings
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True
API_RELOAD=True
API_WORKERS=1

# Database Configuration (PostgreSQL/SQLite)
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/poe_knowledge.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Vector Database (ChromaDB)
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=poe_knowledge

# LLM Provider Configuration
# -----------------------------------------------------------------------------
# Options: openai, anthropic, ollama, lmstudio
LLM_PROVIDER=openai

# OpenAI Settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Anthropic Settings (if using anthropic provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=2000

# Ollama Settings (if using ollama provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TEMPERATURE=0.7

# LM Studio Settings (if using lmstudio provider)
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=local-model
LMSTUDIO_TEMPERATURE=0.7

# Embedding Provider Configuration
# -----------------------------------------------------------------------------
# Options: local, ollama, lmstudio, openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# OpenAI Embeddings (if using openai provider)
EMBEDDING_OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Ollama Embeddings (if using ollama provider)
EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LM Studio Embeddings (if using lmstudio provider)
EMBEDDING_LMSTUDIO_BASE_URL=http://localhost:1234

# RAG Pipeline Settings
# -----------------------------------------------------------------------------
RAG_TOP_K_RESULTS=3
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_SCORE_THRESHOLD=0.7

# Scraper Settings
# -----------------------------------------------------------------------------
SCRAPER_RATE_LIMIT_DELAY=2.0
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT=30
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; POEKnowledgeBot/1.0)
SCRAPER_CONCURRENT_REQUESTS=5

# CORS Settings
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Security Settings
# -----------------------------------------------------------------------------
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_KEY_HEADER=X-API-Key

# Logging Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE_PATH=
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
